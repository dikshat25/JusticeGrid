# JusticeGrid Backend Environment Variables

# LLM Providers (Required for multi-agent execution)
GROQ_API_KEY="your_groq_api_key_here"
OPENROUTER_API_KEY="your_openrouter_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"

# Model Selection
GROQ_MODEL="llama-3.1-8b-instant"
OPENROUTER_MODEL="google/gemma-7b-it:free"
LLM_MODEL="gemini-1.5-flash-lite"

# Firebase Credentials (Required for database sync)
# Place your service account JSON file in the backend directory and specify the name here
FIREBASE_CREDENTIALS_PATH="serviceAccountKey.json"

# Server Configuration
PORT=8000
HOST="0.0.0.0"
